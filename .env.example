TELEGRAM_CHAT_ID=123456789

# Media delivery (set to your CloudFront distribution URL in production)
MEDIA_BASE_URL=https://d2spdapo89woam.cloudfront.net
S3_BASE_URL=https://d2spdapo89woam.cloudfront.net

# Admin auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
